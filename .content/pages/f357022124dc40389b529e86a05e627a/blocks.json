    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Google maps indicates a right turn down a vaguely distinct set of car tracks, the map they gave us validates that it’s a shortcut. I turn left, opting for the certainty of the signposts. Soon after that we reach a boom and the roads get sandier. ",
            "link": null
          },
          "annotations": {
