    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I’m a bit liberal with the 4x4 low range, but we make steady progress. Each sand dune threatens to be the last, yet the winding sandy road with encroaching bushes makes the time fly. ",
            "link": null
          },
          "annotations": {
