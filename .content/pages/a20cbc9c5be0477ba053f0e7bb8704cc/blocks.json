    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We find a quiet spot to watch the sun set and toot a zoot. The golden light beckons us into the water and we float around in bliss. Actually I sink quite a lot; I’m really not used to the lack of salt and find myself at a point of comfortable buoyancy only when my eyes are above the surface. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "We find a quiet spot to watch the sun set and toot a zoot. The golden light beckons us into the water and we float around in bliss. Actually I sink quite a lot; I’m really not used to the lack of salt and find myself at a point of comfortable buoyancy only when my eyes are above the surface. ",
          "href": null
        }
      ],
      "color": "default"
