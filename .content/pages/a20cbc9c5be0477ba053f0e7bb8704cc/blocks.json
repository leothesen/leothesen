    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We stop off for some photos at an enormous baobab tree on the side of the road. It could be thousands of years old. The road has turned to tar again and the winding pass through the mountains is truly incredible. We arrive in Cape Maclear and drive down the main road just one row of houses from the beach until we find a little restaurant that seems to offer a shelter from the heat and some good food.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "We stop off for some photos at an enormous baobab tree on the side of the road. It could be thousands of years old. The road has turned to tar again and the winding pass through the mountains is truly incredible. We arrive in Cape Maclear and drive down the main road just one row of houses from the beach until we find a little restaurant that seems to offer a shelter from the heat and some good food.",
