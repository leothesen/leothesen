    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Crabs scuttle down the beach ahead of us. Seemingly playing in the waves. As the most evolved physical form of life, it appears that they have an abundance of energy to play games; go crabs. We chase a couple of them around to add to their fun. ",
            "link": null
          },
          "annotations": {
