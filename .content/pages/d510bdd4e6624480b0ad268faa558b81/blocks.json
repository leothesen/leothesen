    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The conversation has kept coming back to the point that we don’t really want to leave here on Monday to go to work in Tofu, and trying to find ways to work from the beach here. We spot a light on in a lodge - and guess that they have electricity - upon Googling it find a photo with a perfect wave in the exact spot that we’re standing: bingo. Now we just need the wind to turn and the swell to pick up. Even if it doesn’t I’m so grateful to be here. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The conversation has kept coming back to the point that we don’t really want to leave here on Monday to go to work in Tofu, and trying to find ways to work from the beach here. We spot a light on in a lodge - and guess that they have electricity - upon Googling it find a photo with a perfect wave in the exact spot that we’re standing: bingo. Now we just need the wind to turn and the swell to pick up. Even if it doesn’t I’m so grateful to be here. ",
          "href": null
        }
      ],
      "color": "default"
