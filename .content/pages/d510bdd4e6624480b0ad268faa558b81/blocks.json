  {
    "object": "block",
    "id": "fcbd19b2-7cd8-48c9-9b50-1cb0a80abae7",
    "parent": {
      "type": "page_id",
      "page_id": "d510bdd4-e662-4480-b0ad-268faa558b81"
    },
    "created_time": "2023-09-30T20:09:00.000Z",
    "last_edited_time": "2023-09-30T20:12:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "It’s my turn to drive, and wow I got the best part of the road. The sand deepens and the four wheel drive comes on. The speed decreases and it feels as if we are in a ship navigating an angry ocean of sand. Honestly it was one of the most enjoyable drives of my life. We traverse a the base of an enormous sand dune skirting the coast. Finally we’re wedged between it and dense mangroves. Bouncing along trying to keep momentum up. There was always just enough possibility of getting stuck to keep it exhilarating. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "It’s my turn to drive, and wow I got the best part of the road. The sand deepens and the four wheel drive comes on. The speed decreases and it feels as if we are in a ship navigating an angry ocean of sand. Honestly it was one of the most enjoyable drives of my life. We traverse a the base of an enormous sand dune skirting the coast. Finally we’re wedged between it and dense mangroves. Bouncing along trying to keep momentum up. There was always just enough possibility of getting stuck to keep it exhilarating. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
