    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I wake up before my alarm and get stuck into editing V2 of the Bovineiterology video. The first iteration suffered from a technical malfunction preventing it from being exported, but it also suffered from being an hour long. Watching it with Jordan I realised that it was indeed a little too long. So this time I aim to keep it down to half an hour, and I definitely think that it is better for it. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I wake up before my alarm and get stuck into editing V2 of the Bovineiterology video. The first iteration suffered from a technical malfunction preventing it from being exported, but it also suffered from being an hour long. Watching it with Jordan I realised that it was indeed a little too long. So this time I aim to keep it down to half an hour, and I definitely think that it is better for it. ",
