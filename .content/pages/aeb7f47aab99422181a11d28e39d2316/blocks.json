    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Jordan and I head over to Fred’s house. We make ourselves comfortable and lock into a fun day of work. Bolognaise on toast with melted cheese and avo for lunch. We have several coffees and it begins to feel like a university study session with friends.",
            "link": null
          },
          "annotations": {
