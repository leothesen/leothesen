    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "A early surf alarm goes off but gravity feels twice its normal strength and the snooze button is the only thing my brain moves for. Finally, at 7am I stir and take a glance at the waves from the fence. It warrants a coffee and further inspection after breakfast. ",
            "link": null
          },
