    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "After two months of serious work and busy social life, leading into the excitement of Joburg and straight into travelling to JBay and that whole adventure has been busy. Living in a digs and being quite involved in the Muizenberg social scene has left me with little alone time. I realise that today is the first day in months that I’ve spent all by myself. It’s long overdue and I really soak it up. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "After two months of serious work and busy social life, leading into the excitement of Joburg and straight into travelling to JBay and that whole adventure has been busy. Living in a digs and being quite involved in the Muizenberg social scene has left me with little alone time. I realise that today is the first day in months that I’ve spent all by myself. It’s long overdue and I really soak it up. ",
          "href": null
        }
      ],
