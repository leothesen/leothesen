    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Standing in an elevator which stops on every floor, doors opening and closing with recorded voice announcing the obvious: “doors opening”, all the people in the life either look up or down. Nobody keeps their eyes at eye level. The moment the “doors opening” is announced on the floor that we’re all heading to, heads recalibrate to centre. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Standing in an elevator which stops on every floor, doors opening and closing with recorded voice announcing the obvious: “doors opening”, all the people in the life either look up or down. Nobody keeps their eyes at eye level. The moment the “doors opening” is announced on the floor that we’re all heading to, heads recalibrate to centre. ",
          "href": null
        }
      ],
