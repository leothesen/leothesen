    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Burnt out aircrafts, lying waiting to die as you land in Joburg isn’t a good look. ",
            "link": null
          },
          "annotations": {
            "bold": false,
