    "parent": {
      "type": "page_id",
      "page_id": "0f54a57b-7eb0-4c3b-b1e8-9e379510919f"
    },
    "created_time": "2023-10-18T14:51:00.000Z",
    "last_edited_time": "2023-10-18T14:52:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "After four runs up and down the river I needed to get into the ocean. Diving into the warm water with a wetsuit and fins was physical nostalgia. I became a child again. Bodysurfing right into the sand repeatedly brought back memories long gone of learning to feel comfortable in the ocean. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "After four runs up and down the river I needed to get into the ocean. Diving into the warm water with a wetsuit and fins was physical nostalgia. I became a child again. Bodysurfing right into the sand repeatedly brought back memories long gone of learning to feel comfortable in the ocean. ",
          "href": null
        }
      ],
