  {
    "object": "block",
    "id": "33cdcf22-37f1-43f4-958b-2d024bd95840",
    "parent": {
      "type": "page_id",
      "page_id": "0f54a57b-7eb0-4c3b-b1e8-9e379510919f"
    },
    "created_time": "2023-10-18T14:49:00.000Z",
    "last_edited_time": "2023-10-18T14:51:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We swam out across the deep river, kicking on our back with calves burning. Fish traps to the left and the ocean to the right, goggles over the head obscuring the sky. All it takes is to jump into the river near the mouth and be swept upstream by the tide watching tropical fish, reef, strange assortments of neglected human discards and the great reaches of underwater dunes flash past. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "We swam out across the deep river, kicking on our back with calves burning. Fish traps to the left and the ocean to the right, goggles over the head obscuring the sky. All it takes is to jump into the river near the mouth and be swept upstream by the tide watching tropical fish, reef, strange assortments of neglected human discards and the great reaches of underwater dunes flash past. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
