    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We cruise around the deserted airport looking for a restaurant. After a full loop we decide to go to the lounge that Jordan can get into for free. I decide to use some of my Splitwise credit to buy my entry. ",
            "link": null
