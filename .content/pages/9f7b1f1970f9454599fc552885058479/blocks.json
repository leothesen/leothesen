    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I do love early mornings for getting things done. I polish off quite a few things in my todo list, one of them being updating my neglected travel journal - and realise that I might need to head over to the bank to pick up a card so that I have a backup. ",
            "link": null
