    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I wake up at 5am in an attempt to be so tired at 6pm that I will be able to get a few hours sleep before we need to get to the airport at 11pm. When I’m pottering around in the dark I head the distinct sound of Boots - Tamara’s cat who is staying here while she’s in Kenya - falling off the balcony. It’s dark and confusing at this hour but I see him skunk off into the bush. Jordan is still sleeping and quite unsure of what I’m saying to her. I quickly finish off my coffee and go find him in a bush, luckily unhurt. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I wake up at 5am in an attempt to be so tired at 6pm that I will be able to get a few hours sleep before we need to get to the airport at 11pm. When I’m pottering around in the dark I head the distinct sound of Boots - Tamara’s cat who is staying here while she’s in Kenya - falling off the balcony. It’s dark and confusing at this hour but I see him skunk off into the bush. Jordan is still sleeping and quite unsure of what I’m saying to her. I quickly finish off my coffee and go find him in a bush, luckily unhurt. ",
          "href": null
        }
      ],
      "color": "default"
