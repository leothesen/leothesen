    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I’m feeling exhausted in the car but keep focussed against all odds and make it there and back safely. It’s lovely to see Ivan, he is his usual extremely enthusiastic self and we have a great brief chat. I finish up the last of the packing and we’re all set! Jordan and I sit with Kate for dinner and eat the leftover stir fry then have a shower and get into bed at 7pm. We both put on a mediation and I actually manage to sleep deeply until 9:40pm.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I’m feeling exhausted in the car but keep focussed against all odds and make it there and back safely. It’s lovely to see Ivan, he is his usual extremely enthusiastic self and we have a great brief chat. I finish up the last of the packing and we’re all set! Jordan and I sit with Kate for dinner and eat the leftover stir fry then have a shower and get into bed at 7pm. We both put on a mediation and I actually manage to sleep deeply until 9:40pm.",
          "href": null
        }
      ],
      "color": "default"
