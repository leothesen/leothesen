    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I head over to The Whippet cafe to meet Fred. When I arrive I ask Mary if she’s seen a tall guy with a new short haircut and rippling muscles, a laugh; Fred is sitting at a table 1m away. We get stuck into some good coffee and food, some work and a great conversation about effective altruism and our stance on it.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
