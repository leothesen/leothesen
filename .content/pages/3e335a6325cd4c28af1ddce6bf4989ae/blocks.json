    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I walk down to the point with my breakfast and watch David get a couple good ones. The South Westerly is blowing, but the point is clean and consistent. David gets a solid one and that does it for me - I run back to the car to put my wetsuit on and grab The Custard Queen (6’8” yellow single fin).",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I walk down to the point with my breakfast and watch David get a couple good ones. The South Westerly is blowing, but the point is clean and consistent. David gets a solid one and that does it for me - I run back to the car to put my wetsuit on and grab The Custard Queen (6’8” yellow single fin).",
          "href": null
        }
      ],
