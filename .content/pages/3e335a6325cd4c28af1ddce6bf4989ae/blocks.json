    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I hop in through the keyhole at the top as it looks like the current down the point is quite strong, I make it out with ease. Out at the backline I’m greeted by David and Chris who are frothing. We begin the relentless paddle up the point against the current. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I hop in through the keyhole at the top as it looks like the current down the point is quite strong, I make it out with ease. Out at the backline I’m greeted by David and Chris who are frothing. We begin the relentless paddle up the point against the current. ",
          "href": null
        }
      ],
      "color": "default"
    },
