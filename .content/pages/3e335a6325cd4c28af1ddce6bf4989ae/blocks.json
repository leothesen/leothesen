  {
    "object": "block",
    "id": "eeb4fb74-f77c-4f87-95bc-90ec944874ec",
    "parent": {
      "type": "page_id",
      "page_id": "3e335a63-25cd-4c28-af1d-dce6bf4989ae"
    },
    "created_time": "2022-07-31T14:16:00.000Z",
    "last_edited_time": "2022-08-03T08:05:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "On my second jump off the rocks I spot a fin in the distance. Just a single fin. I wait it out and luckily see and second find, then a third and then countless fins riding the set into the bay. I jump into the water excitedly, neglecting caution. A set comes through and I have to really paddle to avoid being washed onto the rocks. When I finally make it out beyond the breaking waves I’m next to David and we paddle through an immense pod of dolphins. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "On my second jump off the rocks I spot a fin in the distance. Just a single fin. I wait it out and luckily see and second find, then a third and then countless fins riding the set into the bay. I jump into the water excitedly, neglecting caution. A set comes through and I have to really paddle to avoid being washed onto the rocks. When I finally make it out beyond the breaking waves I’m next to David and we paddle through an immense pod of dolphins. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
