  {
    "object": "block",
    "id": "4ac15e6f-3d3e-45a7-a917-8cd97a2f4f27",
    "parent": {
      "type": "page_id",
      "page_id": "3e335a63-25cd-4c28-af1d-dce6bf4989ae"
    },
    "created_time": "2022-07-31T14:20:00.000Z",
    "last_edited_time": "2022-07-31T14:23:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I find myself at the bottom of the rocks, deliberating whether I should brave the current for one more. David calls it there - his arms no longer able. I slowly start paddling up, looking for a my last wave. There is a large grey shape underneath me, luckily it’s tail moving up and down. A pod of about ten dolphins emerge around me and slowly paddle with me up the point back to the takeoff area. They go to sit a bit further out and catch two of the set waves - careening towards me. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I find myself at the bottom of the rocks, deliberating whether I should brave the current for one more. David calls it there - his arms no longer able. I slowly start paddling up, looking for a my last wave. There is a large grey shape underneath me, luckily it’s tail moving up and down. A pod of about ten dolphins emerge around me and slowly paddle with me up the point back to the takeoff area. They go to sit a bit further out and catch two of the set waves - careening towards me. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
