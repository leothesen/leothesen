    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "David tells me about a wave called Shark Point that might have some waves this week. Mikey February surfed it in ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "David tells me about a wave called Shark Point that might have some waves this week. Mikey February surfed it in ",
          "href": null
        },
        {
          "type": "text",
          "text": {
            "content": "Sonic Souvenirs",
            "link": {
              "url": "https://www.youtube.com/watch?v=15VU_mbcrB0"
            }
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Sonic Souvenirs",
          "href": "https://www.youtube.com/watch?v=15VU_mbcrB0"
        },
        {
          "type": "text",
          "text": {
            "content": " (along with Lwandile). It sparks something inside of me and suddenly I’m feeling ready to leave Mdumbi after what has been such a magical time.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": " (along with Lwandile). It sparks something inside of me and suddenly I’m feeling ready to leave Mdumbi after what has been such a magical time.",
          "href": null
        }
      ],
