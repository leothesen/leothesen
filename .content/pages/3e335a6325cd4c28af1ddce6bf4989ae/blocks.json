    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I get another long one and find myself walking back up the point with a smile on my face. Two whales begin sharing the fun, synchronising their breaches. Everyone is ecstatic in the water - hooting at this amazing situation. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I get another long one and find myself walking back up the point with a smile on my face. Two whales begin sharing the fun, synchronising their breaches. Everyone is ecstatic in the water - hooting at this amazing situation. ",
          "href": null
        }
      ],
      "color": "default"
