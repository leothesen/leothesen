    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I’m absolutely exhausted after all the excitement. It takes me an hour to make coffee and a pasta. I head over to the common room to excitedly find out that there is a wealth of footage that Wayne has taken from the point. I put together this little video as quickly as possible to capture this wonderful surf. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I’m absolutely exhausted after all the excitement. It takes me an hour to make coffee and a pasta. I head over to the common room to excitedly find out that there is a wealth of footage that Wayne has taken from the point. I put together this little video as quickly as possible to capture this wonderful surf. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
