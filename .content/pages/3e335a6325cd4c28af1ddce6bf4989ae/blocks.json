  {
    "object": "block",
    "id": "348ea921-520c-42e8-a9d2-c48395e9ae1d",
    "parent": {
      "type": "page_id",
      "page_id": "3e335a63-25cd-4c28-af1d-dce6bf4989ae"
    },
    "created_time": "2022-07-31T14:12:00.000Z",
    "last_edited_time": "2022-08-03T08:05:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The ocean is alive. The wind is blowing. The waves are great, but require effort to find. I’m happy with my decision of boards mainly for the ease of paddling. The Custard Queen is able to glide through the choppy water and easily into waves. As always - she is able to perform her lovely roundhouse into the foam on command and it turns into the right way to ride Mdumbi today.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The ocean is alive. The wind is blowing. The waves are great, but require effort to find. I’m happy with my decision of boards mainly for the ease of paddling. The Custard Queen is able to glide through the choppy water and easily into waves. As always - she is able to perform her lovely roundhouse into the foam on command and it turns into the right way to ride Mdumbi today.",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
