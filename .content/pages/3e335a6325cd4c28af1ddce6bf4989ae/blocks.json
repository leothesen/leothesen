    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Knock Knock Knock on the canopy. David is here! About an hour earlier than he said he would arrive - I love it. The clothes come on and the excitement is high. David is unable to wait for me to surf and he’s in the water shortly after that. I try my best to speed my way through a coffee and oats, but Zingi is a little too cute to not pay attention to. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Knock Knock Knock on the canopy. David is here! About an hour earlier than he said he would arrive - I love it. The clothes come on and the excitement is high. David is unable to wait for me to surf and he’s in the water shortly after that. I try my best to speed my way through a coffee and oats, but Zingi is a little too cute to not pay attention to. ",
          "href": null
        }
      ],
      "color": "default"
