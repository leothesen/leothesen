    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "A swift morning pack up commences in the rain. I don’t feel apathetic towards it in the slightest, rather energised. That being said I spend roughly 50% of the time watching the waves; big, stormy and peeling down the point. They finally capture my attention enough to suit up and head out. ",
            "link": null
          },
          "annotations": {
