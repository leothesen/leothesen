    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "On the flight to Padang I have my first proper chat in Indonesian. The woman sitting next to me is a Paediatrician - she’s curious in me and eager to show me pictures of her family and a trip they took to the Mentawai islands a few years ago. ",
            "link": null
          },
          "annotations": {
