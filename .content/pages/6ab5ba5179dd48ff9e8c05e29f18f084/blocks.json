    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I’m writing this from Padang. A warm blanket of 30 degree humidity envelops everything. A local man lounges on a bean bag near me listening to Fred Again.. and sounds of the city drift into the rooftop. I’m drinking the local coffee - Kapal Api - the nostalgia is overwhelming. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I’m writing this from Padang. A warm blanket of 30 degree humidity envelops everything. A local man lounges on a bean bag near me listening to Fred Again.. and sounds of the city drift into the rooftop. I’m drinking the local coffee - Kapal Api - the nostalgia is overwhelming. ",
          "href": null
