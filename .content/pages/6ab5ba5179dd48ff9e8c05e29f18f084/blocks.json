      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Jay greets us at Kokos with full exuberance and the hospitality of someone who genuinely cares. Air conditioning is welcome! We drink our first Bintang of the trip on the roof and head in for bed. ",
            "link": null
