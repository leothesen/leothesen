    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Then we’re in Jakarta. Overworked air-conditioning units have almost given up and the terminal is probably the most humid place on earth. Sweat patches and all, we march up and down: collecting bags, checking them in, going through security and try to find a long overdue coffee. We settle for an overpriced Matcha at Starbucks. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Then we’re in Jakarta. Overworked air-conditioning units have almost given up and the terminal is probably the most humid place on earth. Sweat patches and all, we march up and down: collecting bags, checking them in, going through security and try to find a long overdue coffee. We settle for an overpriced Matcha at Starbucks. ",
          "href": null
        }
      ],
      "color": "default"
