    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We’re collected by the lovely people from Kokos hostel. The drive from the airport, through the chaotic, organic city of Padang is full of cues for my memory to bring back situations from six years ago. The taxi driver and I have a sweet observational conversation on all the new buildings and shops that have sprung up around the city. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "We’re collected by the lovely people from Kokos hostel. The drive from the airport, through the chaotic, organic city of Padang is full of cues for my memory to bring back situations from six years ago. The taxi driver and I have a sweet observational conversation on all the new buildings and shops that have sprung up around the city. ",
          "href": null
        }
      ],
      "color": "default"
