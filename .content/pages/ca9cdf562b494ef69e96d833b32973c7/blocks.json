    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "There is no alarm set this fine Saturday morning. I have a suspicion that the swell is going to be late, and low tide is only low at 11am. Rain greets me at around 6am and it’s a loverly snooze through the morning with the comforting sounds of the pitter patter on Ralph’s roof. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "There is no alarm set this fine Saturday morning. I have a suspicion that the swell is going to be late, and low tide is only low at 11am. Rain greets me at around 6am and it’s a loverly snooze through the morning with the comforting sounds of the pitter patter on Ralph’s roof. ",
          "href": null
        }
      ],
      "color": "default"
