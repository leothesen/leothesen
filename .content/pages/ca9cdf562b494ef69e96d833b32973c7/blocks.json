    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I make a coffee and take a stroll down to the point to watch the waves. I bump into Wayne who has come to join Bryan and Doro. Chris joins me on the point and we talk about suggestions and things to do around Jeffreys Bay and Cape St Francis when he heads down that way next week ",
            "link": null
          },
