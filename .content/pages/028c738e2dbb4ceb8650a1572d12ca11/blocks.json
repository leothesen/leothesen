    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The plan was to leave today. I make some oats and another coffee. I’m weighing up the rain forecast for this weekend with the fact that there might be some waves on Saturday and I’m not too sure what I should do. I look at the time and it’s coming closer to 11am. With a 5 hour drive ahead of me and some shopping that I have to do. And then it’s decided - I’m going to stay the day and try leave early tomorrow morning. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The plan was to leave today. I make some oats and another coffee. I’m weighing up the rain forecast for this weekend with the fact that there might be some waves on Saturday and I’m not too sure what I should do. I look at the time and it’s coming closer to 11am. With a 5 hour drive ahead of me and some shopping that I have to do. And then it’s decided - I’m going to stay the day and try leave early tomorrow morning. ",
          "href": null
        }
      ],
      "color": "default"
