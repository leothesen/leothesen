    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Kim goes well but I’m feeling a bit pap; so I made a few mistakes and fall behind the peel of the wave. I still get in a couple good roundhouses and snaps in that feel good. There are dolphins that pass under our boards, birds and a glassy ocean. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Kim goes well but I’m feeling a bit pap; so I made a few mistakes and fall behind the peel of the wave. I still get in a couple good roundhouses and snaps in that feel good. There are dolphins that pass under our boards, birds and a glassy ocean. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
