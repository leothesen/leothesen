      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "A beautiful run down the beach and I reach the Mdumbi mouth. I take off my gear and test the depth - it’s about chest deep at the most. With the hydration pack in the dry bag I go across but the tide is pulling quickly and there are some holes in the sand; so there is some swimming. ",
            "link": null
          },
          "annotations": {
