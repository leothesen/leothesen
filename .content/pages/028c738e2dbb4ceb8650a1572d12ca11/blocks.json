    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The current starts up again and the paddle commences. After a good one I am walking back up the beach and decide to go in for one last one. When I make it out to the back I feel the first breaths of the Easterly wind coming up - thank goodness. I take a nice one to the beach and walk back home.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The current starts up again and the paddle commences. After a good one I am walking back up the beach and decide to go in for one last one. When I make it out to the back I feel the first breaths of the Easterly wind coming up - thank goodness. I take a nice one to the beach and walk back home.",
          "href": null
        }
      ],
      "color": "default"
