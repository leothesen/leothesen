    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I simultaneously snooze four alarms that desperately try and wake me up for a dawnie. I get out of bed and word in the backpackers is that the waves are good. I wolf down a coffee and peanut butter Provita breakfast. ",
            "link": null
          },
