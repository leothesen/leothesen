    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Sarah joins me in the common room; a Belgian woman travelling Africa. We have a great chat about South Africa and Bryan and Doro join me us for a cute dinner. We go outside to watch the lightning storm and Doro and Bryan and really bring up some amazing topics - about love, surfing, health and their take on yoga and wellness.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Sarah joins me in the common room; a Belgian woman travelling Africa. We have a great chat about South Africa and Bryan and Doro join me us for a cute dinner. We go outside to watch the lightning storm and Doro and Bryan and really bring up some amazing topics - about love, surfing, health and their take on yoga and wellness.",
