    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Running down with Kim and I’m watching the cyclists come past again - helicopters overhead. The waves are objectively better than yesterday morning - wrapping from behind the rocks all the way through the sandbar. There are no waves that are too big, and the smaller ones have a great line to them. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
