  {
    "object": "block",
    "id": "65160db1-dad0-433f-9774-3030a0a2d101",
    "parent": {
      "type": "page_id",
      "page_id": "7c29a9e9-0ec1-474d-8aa0-c53c7914be58"
    },
    "created_time": "2022-08-30T12:24:00.000Z",
    "last_edited_time": "2022-08-30T12:29:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Jumping into the water tells a different story. We are swept down to the river before even making it out to the backline. The swell seems to be too South and there are many rogue wide waves breaking, making duck diving a constant feature. The rip is enormous so I bodysurf in and run around - jumping off the rocks at the keyhole. I manage to get one or two and dolphins engulf Dom and I while showing us how to really ride the waves. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Jumping into the water tells a different story. We are swept down to the river before even making it out to the backline. The swell seems to be too South and there are many rogue wide waves breaking, making duck diving a constant feature. The rip is enormous so I bodysurf in and run around - jumping off the rocks at the keyhole. I manage to get one or two and dolphins engulf Dom and I while showing us how to really ride the waves. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
