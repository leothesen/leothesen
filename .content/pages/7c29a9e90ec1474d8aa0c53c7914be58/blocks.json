    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We head back and I tackle the neglected task of cleaning my car, the crates and setting up camp. It feels good to be more organised again, Ralph has been sidelined for quite a few weeks now. Lunch is leftover curry (of which there are at least two more meals left) and it’s easily better than it was last night. ",
            "link": null
          },
          "annotations": {
