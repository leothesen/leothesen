    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We are around spring tides so high tide is just before sunrise - this means that a sleep in is in order. Coffee and a walk down to the point to check the waves; which are looking pretty good! I make Julian and I wait at least ten minutes to see what a full cycle of sets look like. It seems like it’s running and fun, we go to suit up.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "We are around spring tides so high tide is just before sunrise - this means that a sleep in is in order. Coffee and a walk down to the point to check the waves; which are looking pretty good! I make Julian and I wait at least ten minutes to see what a full cycle of sets look like. It seems like it’s running and fun, we go to suit up.",
          "href": null
        }
