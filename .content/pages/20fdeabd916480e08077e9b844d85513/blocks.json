    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The extra legroom is incredible. Legs up, I wasn’t made for airplanes. It’s a rather strange flight time, to take off at about 7pm. You’d think that it would be easy to get straight to sleep but alas. Cait and I are in half-sleep for many hours, interspersed by eating, reading, Cait watches a strange show. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The extra legroom is incredible. Legs up, I wasn’t made for airplanes. It’s a rather strange flight time, to take off at about 7pm. You’d think that it would be easy to get straight to sleep but alas. Cait and I are in half-sleep for many hours, interspersed by eating, reading, Cait watches a strange show. ",
          "href": null
        }
      ],
      "color": "default"
