  {
    "object": "block",
    "id": "03b35d74-f970-4ac8-a8d9-3be8998f544a",
    "parent": {
      "type": "page_id",
      "page_id": "9318fa1b-52af-4ef3-a66d-927f8478d050"
    },
    "created_time": "2024-01-04T15:18:00.000Z",
    "last_edited_time": "2024-01-04T15:18:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Change can incite fear. The antidote for fear is often clarity. Clarity, in a partnership, is brought about through communication. I’ve kind of landed on communication being the absolute cornerstone of a relationship. Not all communication has to be verbal and linguistic, yet if two people are able to clearly communicate thoughts, ideas, emotions, sensations, biases, fears and triumphs - then I think that they have what it takes to embark on the adventure that is the transience of life, together. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Change can incite fear. The antidote for fear is often clarity. Clarity, in a partnership, is brought about through communication. I’ve kind of landed on communication being the absolute cornerstone of a relationship. Not all communication has to be verbal and linguistic, yet if two people are able to clearly communicate thoughts, ideas, emotions, sensations, biases, fears and triumphs - then I think that they have what it takes to embark on the adventure that is the transience of life, together. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
