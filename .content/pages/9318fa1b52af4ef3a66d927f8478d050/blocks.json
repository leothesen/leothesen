  {
    "object": "block",
    "id": "08572648-cefc-441e-beb4-6fcd66bdd05f",
    "parent": {
      "type": "page_id",
      "page_id": "9318fa1b-52af-4ef3-a66d-927f8478d050"
    },
    "created_time": "2024-01-04T15:18:00.000Z",
    "last_edited_time": "2024-01-04T15:18:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "A partner is not someone who you find and try and lock in time, preserving their personality traits or youthful looks. A partner is someone who will accompany you through time on a journey where everything slowly changes until even the memory of who you both where when you met is different from the truth. I don’t mean to make it sound scary - nature is change, we are change, we will go through this change alone whether we like it or not; how beautiful to be able to do it with someone else. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "A partner is not someone who you find and try and lock in time, preserving their personality traits or youthful looks. A partner is someone who will accompany you through time on a journey where everything slowly changes until even the memory of who you both where when you met is different from the truth. I don’t mean to make it sound scary - nature is change, we are change, we will go through this change alone whether we like it or not; how beautiful to be able to do it with someone else. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
