    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "At 5pm a bell rings. The company with who we share the office don’t work on Friday and it’s time for drinks and a game. We all give our birth dates and years and Oscar compiles a playlist of the songs that were top of the charts for that day. He plays the songs one by one and we have to guess the name, the artist and the person‘s who‘s birth year it correspends to. We tally up the points and our team wins.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "At 5pm a bell rings. The company with who we share the office don’t work on Friday and it’s time for drinks and a game. We all give our birth dates and years and Oscar compiles a playlist of the songs that were top of the charts for that day. He plays the songs one by one and we have to guess the name, the artist and the person‘s who‘s birth year it correspends to. We tally up the points and our team wins.",
