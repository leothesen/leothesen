    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We were set to leave this morning, but poor Jordan was hit but a stomach bug in the night. We’re just taking it super easy today. She’s sleeping and I’m hanging out in the room with her catching up with some travel journals. I eat breakfast on the stoep outside our room.",
            "link": null
          },
