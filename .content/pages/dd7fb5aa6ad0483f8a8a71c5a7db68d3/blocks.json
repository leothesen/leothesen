    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I wake up to see the sunrise and check the waves. It’s blood orange and moody. I make a coffee and oats in a full kitchen. The Richard’s Bay crew are upset “skunked again - the waves are small” they say. Hayley sits at the table with a coffee and we chat - she used to work at Aerobotics and we have some mutual friends. We take a walk down to the point to watch the waves.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I wake up to see the sunrise and check the waves. It’s blood orange and moody. I make a coffee and oats in a full kitchen. The Richard’s Bay crew are upset “skunked again - the waves are small” they say. Hayley sits at the table with a coffee and we chat - she used to work at Aerobotics and we have some mutual friends. We take a walk down to the point to watch the waves.",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
