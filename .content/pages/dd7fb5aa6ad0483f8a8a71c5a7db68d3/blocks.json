      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "It’s small, clean and beautiful; I decide to go for a paddle. Cam and Bas are putting on their spear diving suits using some slippery powder. I stroll down to the point and paddle out into the empty lineup. ",
            "link": null
          },
