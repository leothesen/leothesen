    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "There are some good smaller waves running past the top of the point. I snag a couple and manage to get some little whacks and turns in. Christian comes to join me and the waves start getting better. I get a couple all the way down to the beach and walk around. My arms burn and body feels lethargic after the past week of surfing. ",
            "link": null
          },
