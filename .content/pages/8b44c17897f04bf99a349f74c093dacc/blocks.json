    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I wake up in the car in the campsite in Hogsback and know that I’m not up to do any hiking or running. I aim to be back by the coast on Wednesday as the surf is favorable, so this marks the last day in Hogsback. Which is fine with me, it’s actually been the most incredible and restful time. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I wake up in the car in the campsite in Hogsback and know that I’m not up to do any hiking or running. I aim to be back by the coast on Wednesday as the surf is favorable, so this marks the last day in Hogsback. Which is fine with me, it’s actually been the most incredible and restful time. ",
          "href": null
        }
      ],
      "color": "default"
