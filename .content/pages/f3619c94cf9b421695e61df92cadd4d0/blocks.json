    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The drive goes quickly - the route is familiar. When I hit the dirt road for the last forty minutes of the drive I slow right down and just enjoy it. Arriving at Mdumbi backpackers for the third time in a month is great - I’m given such a warm reception and welcome back. Julian comes out of his rondavel for a hug and a hello. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The drive goes quickly - the route is familiar. When I hit the dirt road for the last forty minutes of the drive I slow right down and just enjoy it. Arriving at Mdumbi backpackers for the third time in a month is great - I’m given such a warm reception and welcome back. Julian comes out of his rondavel for a hug and a hello. ",
          "href": null
