    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I’m driving through Mthatha when I am struck by a mental reminder to buy a “Koi” portable watercolour set. Painting is not something that I find myself doing very often at all - but it’s definitely been something that I want to get into. When I saw Fred painting a cute little scene of the Mdumbi backpacker’s sunroom I really thought that this was the sign that I was looking for. Mthatha surely has a art supply store? It did! And I walked out with a kiddies watercolour set and two brushes. I’m excited to make use of the Moleskine book that my mom gifted me. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I’m driving through Mthatha when I am struck by a mental reminder to buy a “Koi” portable watercolour set. Painting is not something that I find myself doing very often at all - but it’s definitely been something that I want to get into. When I saw Fred painting a cute little scene of the Mdumbi backpacker’s sunroom I really thought that this was the sign that I was looking for. Mthatha surely has a art supply store? It did! And I walked out with a kiddies watercolour set and two brushes. I’m excited to make use of the Moleskine book that my mom gifted me. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
