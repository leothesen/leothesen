    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The aim is to get to Mdumbi early to have a surf. In actuality it turns out that leaving quickly is still very hard for me. A coffee, breakfast and one too many long goodbyes later I’m on the road.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
