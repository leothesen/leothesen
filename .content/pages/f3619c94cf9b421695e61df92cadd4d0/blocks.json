    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I nearly get blown off the hill while hanging onto the massive longboard. Kim proves much easier on the water back down. Everyone else gets out the water and I struggle through relentless duck dives while searching for the illusive left that I saw previously. I’m feeling rather shaky on my feet but manage to find one that offers as cutback on the face and floater and I’m content to go back for a warm shower and some dinner.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
