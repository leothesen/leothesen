    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Simply put the surf is just absolute fun. Waist high peeling lefts breaking going all the way to the beach. It’s soft and sometimes fades away but there are a few that come through with a good line. I surf well and get a huge amount of waves (more than Garmin registers). Marcus joins me out there for the sunset glory. ",
            "link": null
          },
          "annotations": {
