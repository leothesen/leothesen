    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Wind slams the car in the early morning - the predecessor of the cold front to come. My sleep is disrupted and drags on longer than normal. I take a walk down to the point to see what swell there is; not much. I’m trying to get back into doing some exercise so a few glute and core exercises happen in the sun.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Wind slams the car in the early morning - the predecessor of the cold front to come. My sleep is disrupted and drags on longer than normal. I take a walk down to the point to see what swell there is; not much. I’m trying to get back into doing some exercise so a few glute and core exercises happen in the sun.",
          "href": null
        }
      ],
      "color": "default"
