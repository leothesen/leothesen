    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I pack the fastpack embarrassingly lightly with just the coffee equipment and jog off down the beach. I’m just going to feel out my body and see how my left ITB is doing. The route is familiar and documented quite a few times in this travel journal already. The significant parts of this trip were listing to my body and testing out some different running styles.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
