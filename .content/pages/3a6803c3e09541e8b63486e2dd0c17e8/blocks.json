      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I take a new route around the final hill before Lwandile; along the coast and see four surfers in the water. The wave is breaking in a completely different place to my previous experiences here, right down at the closeout section on the beach is a little peak running to the sand. ",
            "link": null
          },
          "annotations": {
