    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I did have a little flare up about four kilometres in and begin to take things a bit slower from there. I’m having the suspicion that the slow shuffle jog almost aggravates it more than a really fast run. I hypothesise that an effective way to run a long run would be the powerhike on the ups and down and then just absolutely send the flats.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I did have a little flare up about four kilometres in and begin to take things a bit slower from there. I’m having the suspicion that the slow shuffle jog almost aggravates it more than a really fast run. I hypothesise that an effective way to run a long run would be the powerhike on the ups and down and then just absolutely send the flats.",
          "href": null
        }
      ],
      "color": "default"
