    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "This morning is even slower and I rise at 8am. The normal morning routine follows after that, changed only be a lot of reading. My body is feeling slow and sluggish today. Filen comments on the fact that the ocean drives the mood of people - the calm, quiet and still sea sets the tone. ",
            "link": null
          },
          "annotations": {
