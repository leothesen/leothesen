    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The surf is fun - mostly a Glen Beacheque closeout that offers mostly a floater or two. I do manage to find some rhythm and am quite pleased with my surfing. It’s quite interesting surfing a beach break again after a month or so of only point breaks. You learn to get excited again about a wave that runs for 20m. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The surf is fun - mostly a Glen Beacheque closeout that offers mostly a floater or two. I do manage to find some rhythm and am quite pleased with my surfing. It’s quite interesting surfing a beach break again after a month or so of only point breaks. You learn to get excited again about a wave that runs for 20m. ",
          "href": null
        }
      ],
      "color": "default"
