    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Neil arrives and is immediately a huge character. After a few minutes of his truly ridiculous tales and inappropriate jokes I realise that he has almost exactly the same sense of humor as the rather dubious insurance salesman that I met in Port St Johns named Dean. When I tell him about his resemblance to Dean, he replies with something that I imagine Dean would too: “does Dean also have a great ass?”",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
