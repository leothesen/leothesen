    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Around lunch time I feel the wind change and take go back to take a look at the point. It’s similar to this morning just maybe slightly cleaner. I paddle out alone and Jude comes to join me in boardshorts a little while later.",
            "link": null
          },
          "annotations": {
