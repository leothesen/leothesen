      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "After leaving the cafe we pass a large church. We peak inside (looking for stamps) but instead find a sermon in progress. Behind the priest is an enormous gold detailed organ, the pews are full and it has a powerful energy. We watch in awe for a while.",
            "link": null
          },
          "annotations": {
