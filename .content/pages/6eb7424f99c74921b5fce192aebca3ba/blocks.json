    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I don’t see many other cars other than farm bakkies. I’m sure that more than one of them was probably a bit surprised to see a surfboard on the roof out here. Arriving at ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I don’t see many other cars other than farm bakkies. I’m sure that more than one of them was probably a bit surprised to see a surfboard on the roof out here. Arriving at ",
          "href": null
        },
        {
          "type": "text",
          "text": {
            "content": "Tortoni",
            "link": {
              "url": "https://tortoni.co.za/"
            }
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Tortoni",
          "href": "https://tortoni.co.za/"
        },
        {
          "type": "text",
          "text": {
            "content": " a working farm that has a campsite on it. They hadn’t answered my phone calls trying to book a spot - and when I arrived there was nobody really to be seen. I find a campsite and a Great Dane and Golden Retriever come to check me in.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": " a working farm that has a campsite on it. They hadn’t answered my phone calls trying to book a spot - and when I arrived there was nobody really to be seen. I find a campsite and a Great Dane and Golden Retriever come to check me in.",
          "href": null
        }
      ],
      "color": "default"
