    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Interactions with people highlight the hours on our feet. We’re lifted across the river by Terrance in his little fishing boat. On the other side while we’re climbing up out on the Jeep track the ferry man comes stumbling down the hill from the shabeen, confused as to how we managed to get across. We manage to evade what we’ve heard can be quite confrontational requests to pay purely for the fact that you crossed a river out in the Transkei. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
