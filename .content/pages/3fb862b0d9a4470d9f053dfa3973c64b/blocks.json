    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We’ve been looking for a coffee and swim spot for over two hours; the path has a mind off its own as it takes us inland. The midday heat is thick and saps our energy. I make sure to drink a lot of water and take the salt tablets. My body is going great, just my right hip flexor has been lagging behind. Running with the significantly lighter pack has been a bit of a game changer. We walk the climbs, jog the flats and run the descents. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "We’ve been looking for a coffee and swim spot for over two hours; the path has a mind off its own as it takes us inland. The midday heat is thick and saps our energy. I make sure to drink a lot of water and take the salt tablets. My body is going great, just my right hip flexor has been lagging behind. Running with the significantly lighter pack has been a bit of a game changer. We walk the climbs, jog the flats and run the descents. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
