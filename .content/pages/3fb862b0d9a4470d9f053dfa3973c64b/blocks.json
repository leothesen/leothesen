    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We settle into the night and rest our bodies. Fred asks what the meaning of life is as the wind dies we slowly relax. What a beautiful spot to spend the night. I watch the sun right hander peel off with not a surfer in sight. ",
            "link": null
          },
