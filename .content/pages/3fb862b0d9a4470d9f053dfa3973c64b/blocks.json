    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We have a beautiful swim and chill at the end of a Long Beach. A lovely couple from Joburg take their child on a walk down the beach. The ocean is warm and the sun soothing. It’s all quite surreal and I take in the fact that this is actually happening.",
            "link": null
          },
