    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I slept like an absolute rock. It’s challenging to get out of bed but I’m in no rush. While I’m having a coffee Jordan makes us a slice of toast with jam. The jam was a present that I bought her for yesterday’s special day - umsobo jam from the Little Church, which is their speciality. ",
            "link": null
          },
          "annotations": {
