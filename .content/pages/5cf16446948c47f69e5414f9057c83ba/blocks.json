    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "After that I whip together an omlette and we start the day. Jordan is working and all I want to do is potter around at home, play music, pack my bag for tomorrow and relax. I hear a tractor working on a burst pipe in the street and I absolutely have to go check it out. ",
            "link": null
