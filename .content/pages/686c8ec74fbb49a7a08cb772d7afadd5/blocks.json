    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "It all starts with simply recognising all the things that are occurring right now: sights, sounds, feelings, tastes, smells, thoughts, emotions and that intuitive “gut” feeling. That’s easier said that done though; it can be so easy to lose yourself in experience - but most commonly, it can be so easy to become wrapped up in thought. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "It all starts with simply recognising all the things that are occurring right now: sights, sounds, feelings, tastes, smells, thoughts, emotions and that intuitive “gut” feeling. That’s easier said that done though; it can be so easy to lose yourself in experience - but most commonly, it can be so easy to become wrapped up in thought. ",
          "href": null
        }
      ],
