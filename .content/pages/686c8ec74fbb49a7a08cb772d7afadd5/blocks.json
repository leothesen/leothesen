    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "An amalgamation of thoughts, concepts and memories band together to form the ego. The story that the mind continuously tells itself to describe the person that you are. The ego shouldn’t be killed or quelled, it should just be clearly seen for what it is. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "An amalgamation of thoughts, concepts and memories band together to form the ego. The story that the mind continuously tells itself to describe the person that you are. The ego shouldn’t be killed or quelled, it should just be clearly seen for what it is. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
