    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "What are my thoughts on thoughts? These strange things that appear out of nowhere and disappear back to nowhere. These illusive, intangible, formless veils that drift in like sea mist; obscuring all that is real. They are wonderful, yet more powerful that we give credit. ",
            "link": null
          },
          "annotations": {
