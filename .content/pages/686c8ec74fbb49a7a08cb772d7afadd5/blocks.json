  {
    "object": "block",
    "id": "94533afb-6641-4dcd-856d-f953af74baa8",
    "parent": {
      "type": "page_id",
      "page_id": "686c8ec7-4fbb-49a7-a08c-b772d7afadd5"
    },
    "created_time": "2024-01-07T15:55:00.000Z",
    "last_edited_time": "2024-01-07T16:06:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Your mind is a product of all your past experiences. It reacts to situations as per it’s conditioning. Practicing mindfulness, otherwise known as meditation, is a way of adding new conditioning to your mind such you are able to react to situations differently, with wisdom. The goal is for your mind to react to situations with clarity, allowing you to be completely aware of everything that is happening in all moments. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Your mind is a product of all your past experiences. It reacts to situations as per it’s conditioning. Practicing mindfulness, otherwise known as meditation, is a way of adding new conditioning to your mind such you are able to react to situations differently, with wisdom. The goal is for your mind to react to situations with clarity, allowing you to be completely aware of everything that is happening in all moments. ",
          "href": null
        }
      ],
      "color": "default"
