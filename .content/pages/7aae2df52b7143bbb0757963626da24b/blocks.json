    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I arrive in Joburg and give Jozi Jordan a big hug and a kiss. Her new buzz cut is beautiful and her hairline is exceptional. A quick lunch and then we head over to “Howzit” by Picnic and Thrift to watch some live bands in the sun. Kate is coming on and she plays a beautiful set. We sit right in the front row and lose ourselves - it’s been so long since I’ve watched live music; how I’ve missed it.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I arrive in Joburg and give Jozi Jordan a big hug and a kiss. Her new buzz cut is beautiful and her hairline is exceptional. A quick lunch and then we head over to “Howzit” by Picnic and Thrift to watch some live bands in the sun. Kate is coming on and she plays a beautiful set. We sit right in the front row and lose ourselves - it’s been so long since I’ve watched live music; how I’ve missed it.",
          "href": null
        }
      ],
      "color": "default"
