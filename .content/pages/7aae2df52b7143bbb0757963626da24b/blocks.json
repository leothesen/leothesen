    "created_time": "2022-09-11T12:37:00.000Z",
    "last_edited_time": "2022-09-11T12:39:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The drive is pleasant, the road takes me along Sterkfontein damn before it joins the N3 again. The mountains slowly subside to my left and are replaced by the expansive brown farmlands of the Freestate. Alan Watts is the audio for the drive again and I’m absolutely loving it. He goes into depth around how we cannot separate ourselves from the environment and how our language sets up unexamined biases and suppositions that bias our thinking.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The drive is pleasant, the road takes me along Sterkfontein damn before it joins the N3 again. The mountains slowly subside to my left and are replaced by the expansive brown farmlands of the Freestate. Alan Watts is the audio for the drive again and I’m absolutely loving it. He goes into depth around how we cannot separate ourselves from the environment and how our language sets up unexamined biases and suppositions that bias our thinking.",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
