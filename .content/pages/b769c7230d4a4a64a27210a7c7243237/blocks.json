    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We hop onto the bus to go and visit my cousins Kirsten and Robynne for brunch. There is a road closure and we’re off the bus, walk down the closed road and then wait for another bus, luckily we’re early. When we get on the new bus there is a driver change and we’re back on our feet again. We still manage to get to Chinwag’s cafe on time.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "We hop onto the bus to go and visit my cousins Kirsten and Robynne for brunch. There is a road closure and we’re off the bus, walk down the closed road and then wait for another bus, luckily we’re early. When we get on the new bus there is a driver change and we’re back on our feet again. We still manage to get to Chinwag’s cafe on time.",
