    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We say our goodbyes to Molly and Dave - they really have treated us - and head off to Sasha and Georgie where we’ll be staying for the week. They live in a beautiful flat and we’re blown away to see that we have a spare bedroom with a double bed! AAAAAH. We have a cup of tea that turns into dinner and have so much to talk about. We get onto the topic of the London foxes and I say that I really want to see one - Sasha suggests a walk around the neighbourhood to try out luck.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
