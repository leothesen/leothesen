    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Dave wins the Peculator vs Aeropress argument this morning. I end up drinking one of each. I still back the Aeropress - but I’ll give Dave this victory as a thank you for letting us sleep on his couch. ",
            "link": null
          },
