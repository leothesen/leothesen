    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "This is called an Infra thin, as I dicovered by Rob Walker. Originally attributed to Marcel Duchamp. Duchamp defined \"infra thin\" as a poetic notion of sensations or qualities that fall outside the traditional five senses, or “states between states,” as Kenneth Goldsmith phrased it. I see them as experiences that seem to have a little magic, or a story behind them. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "This is called an Infra thin, as I dicovered by Rob Walker. Originally attributed to Marcel Duchamp. Duchamp defined \"infra thin\" as a poetic notion of sensations or qualities that fall outside the traditional five senses, or “states between states,” as Kenneth Goldsmith phrased it. I see them as experiences that seem to have a little magic, or a story behind them. ",
          "href": null
        }
      ],
