    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "It’s early morning the twins are already wanting to play. They’re quickly distracted by the Tupperware with the (what we thought was) finished fish from last night. They pull at the little bits of flesh and skin remaining until there is truly only a skeleton left.",
            "link": null
          },
