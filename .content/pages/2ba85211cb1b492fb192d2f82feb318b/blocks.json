    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Julian goes for a surf and I watch perfect peeling waves before having to join him for an hour over lunch. It’s small, quite clean and good. Waist high peeling rights that form on the shelf and run over the sandbar; almost like a more tropical Mdumbi. It’s not really big enough to let rip, but it’s always a pleasure to ride a long wave. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Julian goes for a surf and I watch perfect peeling waves before having to join him for an hour over lunch. It’s small, quite clean and good. Waist high peeling rights that form on the shelf and run over the sandbar; almost like a more tropical Mdumbi. It’s not really big enough to let rip, but it’s always a pleasure to ride a long wave. ",
          "href": null
        }
      ],
      "color": "default"
