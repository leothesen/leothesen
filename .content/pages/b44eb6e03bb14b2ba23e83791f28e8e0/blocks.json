    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The views of Malawi grow magnificent as we climb the mountains. Valleys extending indefinitely int the direction of what we think must be the lake. Every now and then there is a small wooden craft display on the side of the road. It’s truly a beautiful drive.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The views of Malawi grow magnificent as we climb the mountains. Valleys extending indefinitely int the direction of what we think must be the lake. Every now and then there is a small wooden craft display on the side of the road. It’s truly a beautiful drive.",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
