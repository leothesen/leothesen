    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The Klein Karoo feels different to how I remember it. No longer suffocating, desolate and dead. No longer the absence of an ocean. The calm, yet vibrant stillness is intoxicating. I can’t keep my eyes off the horizon. ",
            "link": null
          },
