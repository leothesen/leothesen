    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Negative space is the key to appreciation here: three trees standing in an isolated cluster increase their presence and accentuate their features. Something that my younger self could never grasp when coming from the abundant coast. ",
            "link": null
          },
          "annotations": {
            "bold": false,
