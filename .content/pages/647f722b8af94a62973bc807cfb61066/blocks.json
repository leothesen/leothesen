    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Philen is in the kitchen making breakfast, we get talking. He tells me about the car accident that he was in that led to him being in a coma. His lost of smell is the only thing that wasn’t able to be healed. It started quite a journey for him. He’s written a book called “My Africa”.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Philen is in the kitchen making breakfast, we get talking. He tells me about the car accident that he was in that led to him being in a coma. His lost of smell is the only thing that wasn’t able to be healed. It started quite a journey for him. He’s written a book called “My Africa”.",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
