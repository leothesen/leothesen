    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I’ve got an early alarm set just incase there are waves this morning. I take a walk down to the point with a coffee and am greeted by small waves and hundreds of dolphins. I spend a little while down there taking it all in.",
            "link": null
          },
          "annotations": {
