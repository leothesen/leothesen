    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I enjoy speaking to him, he’s got a huge amount of lived experience throughout many cultures and places. I ask him questions that I have had on the topic of free will and he answers them beautifully. Just as I get to the real crux of the questions that I’ve been wanting to ask him, I realise that we have a flat tyre. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I enjoy speaking to him, he’s got a huge amount of lived experience throughout many cultures and places. I ask him questions that I have had on the topic of free will and he answers them beautifully. Just as I get to the real crux of the questions that I’ve been wanting to ask him, I realise that we have a flat tyre. ",
          "href": null
        }
      ],
      "color": "default"
