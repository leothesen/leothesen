  {
    "object": "block",
    "id": "8bae43f7-727d-4ace-a018-bbd037f90f3c",
    "parent": {
      "type": "page_id",
      "page_id": "647f722b-8af9-4a62-973b-c807cfb61066"
    },
    "created_time": "2022-09-07T18:22:00.000Z",
    "last_edited_time": "2022-09-07T18:25:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I’m driving through some absolutely chaotic Eastern Cape Town. Google suggested a detour around the main road but I kind of wanted to see what it would be like. Throngs of people emerge from shops and markets and move through the cars. The cars seem to move around the people actually. Walking is faster than driving. Cars hoot. People do U-turns, and then I see them doing another U-turn 20m later. Music blares from taxis. There are dogs, goats and a cow or two amongst it all. Then there’s this pale white dude driving a car with a surfboard on top listening to Allan Watts on full volume with the window down smoking a cigarette. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I’m driving through some absolutely chaotic Eastern Cape Town. Google suggested a detour around the main road but I kind of wanted to see what it would be like. Throngs of people emerge from shops and markets and move through the cars. The cars seem to move around the people actually. Walking is faster than driving. Cars hoot. People do U-turns, and then I see them doing another U-turn 20m later. Music blares from taxis. There are dogs, goats and a cow or two amongst it all. Then there’s this pale white dude driving a car with a surfboard on top listening to Allan Watts on full volume with the window down smoking a cigarette. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
