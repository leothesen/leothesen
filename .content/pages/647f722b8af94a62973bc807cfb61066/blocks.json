    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Tyre is good. Spare is back under the car and I’m on the road. I listen to music happily for a while until Clair de Lune comes on, and it has a very faint Allan Watts monolog in the background. So I immediately pause the song and put on Allan Watts. ",
            "link": null
          },
          "annotations": {
