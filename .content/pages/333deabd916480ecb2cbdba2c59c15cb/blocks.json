            "code": false,
            "color": "default"
          },
          "plain_text": "The WalkingPad comes with the KingSmart app, which is notoriously terrible. Buggy, slow, and requires you to pull out your phone every time you want to change speed or check your stats.",
          "href": null
        }
      ],
      "icon": null,
      "color": "default"
    },
    "archived": false
