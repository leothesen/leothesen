    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I’m absolutely overflowing with excitement when Citymapper tells us we should be taking my first London bus to get to their house. We walk to the stop and then I count the minutes excitedly until the enormous double decker hybrid-electric bus arrives to collect us. Just like the trains I just tap my phone and get in - so good.",
            "link": null
          },
