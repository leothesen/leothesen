    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We arrive in no time and drag our noisy suitcases to their front door. Dave is working from home and Molly is on the phone to the bank so we just make it a quick little stop over. They have a beautiful flat and we have the quickest of catch ups, leave our bags and head over to the Science museum. ",
            "link": null
          },
          "annotations": {
