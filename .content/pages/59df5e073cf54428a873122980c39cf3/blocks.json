    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "A stroll gets us to the Science museum that is absolutely out of this world. As we walk in there are enormous steam engines installed in the floor hissing and spinning away. There is an incredibly well curated exhibit on space exploration, Steven Hawkings, flight, telecommunications and so much more. We’re exhausted, and bewildered, after a few hours and we drag ourselves back home.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "A stroll gets us to the Science museum that is absolutely out of this world. As we walk in there are enormous steam engines installed in the floor hissing and spinning away. There is an incredibly well curated exhibit on space exploration, Steven Hawkings, flight, telecommunications and so much more. We’re exhausted, and bewildered, after a few hours and we drag ourselves back home.",
          "href": null
        }
      ],
      "color": "default"
