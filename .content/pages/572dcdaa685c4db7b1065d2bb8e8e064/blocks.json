    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We’re off to the Tate Modern; a museum that I’ve heard so much about. On the walk we find a box of things on the street - I come away with a bag scale. Something that I’ve often found myself wanting. Finding free things on the street that people are throwing out is truly such a special gem in London. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
