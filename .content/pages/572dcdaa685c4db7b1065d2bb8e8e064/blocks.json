    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "One serious called “Flirt” really draws me in. It’s a style that has made a bit of a resurgence as of late and I’ve always been so intrigued by it. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
