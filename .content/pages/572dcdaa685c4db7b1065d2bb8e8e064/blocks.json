      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Before we enter we do the very clever thing of eating a sandwich on the bench outside the museum. Prepared and fed we enter - and are greeted by thirty meter tall mobile type drapes hanging from the ceiling. Jordan has to feel them. Sounds accompany the piece and we’re thrown into a world of art.",
            "link": null
          },
