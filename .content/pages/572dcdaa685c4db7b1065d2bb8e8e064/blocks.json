    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "It’s raining this morning. Classic cold English rain. I drink my coffee and watch children heading off to school with some serious jackets and gear on - they are well prepared. I do a little bit of writing before Jordan surfaces and then we make our first scrambled eggs and avo toast breakfast in ages. ",
            "link": null
          },
