    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I edge from one work to the next, often reading the accompanying text with wonder. I know that it’s just not possible to see everything so I begin skipping some here and there. I wonder past what looks like a Picasso, double back and am amused to see that it is indeed a Picasso. ",
            "link": null
          },
          "annotations": {
