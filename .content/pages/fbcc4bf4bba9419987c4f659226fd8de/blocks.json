    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I see a numberplate in front of us at a toll gate. It’s a silver Range Rover and I can’t seem to work out the numberplate “Bra i 1”. So I read it out loud to myself, and it clicks. Julian and I take a few hours to get over the hilarity of it. ",
            "link": null
          },
