    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We Uber to the airport without issue. Although the fuel light was on when we got into the car. Jordan sneaks into the airport lounge and plunders their snack collection. It feels exciting traveling to a first world country with a bag full of clothes. ",
            "link": null
          },
          "annotations": {
