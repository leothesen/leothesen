    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We smoke a dirty rollie together by the car watching the waves. The wind and tide had come up, chilling us and causing only the set waves to break. We’re cold and Nas thoroughly enjoyed the flask of coffee so much that there isn’t any left. One pleasant Hilux ride later we’re back at the Mdumbi and saying goodbye to David. Me and Marco have an interesting conversation that both flows and jerks its way around a range of topics. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "We smoke a dirty rollie together by the car watching the waves. The wind and tide had come up, chilling us and causing only the set waves to break. We’re cold and Nas thoroughly enjoyed the flask of coffee so much that there isn’t any left. One pleasant Hilux ride later we’re back at the Mdumbi and saying goodbye to David. Me and Marco have an interesting conversation that both flows and jerks its way around a range of topics. ",
          "href": null
        }
      ],
      "color": "default"
