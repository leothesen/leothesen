    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Okay, Hilux’s are fucking great. We floated over the absolute abolishment of a road with absolutely no discomfort. There’s a bakkie in the road facing our way in a cold valley with high vegetation on either side; someone is flagging us down. Three sleeping faces lined up in the front seat. It turns out that they went out drinking last night and on the way back their car had broken down. They pour out of the car asking for “Amanzi” water. David tows them to try start their car - it doesn’t, he ends up towing them all the way back out the valley. Me and Gareth talk about Indonesia and throw rocks into the bushes. Throwing rocks is one of the pleasures that I indulge in when there is nothing to do.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Okay, Hilux’s are fucking great. We floated over the absolute abolishment of a road with absolutely no discomfort. There’s a bakkie in the road facing our way in a cold valley with high vegetation on either side; someone is flagging us down. Three sleeping faces lined up in the front seat. It turns out that they went out drinking last night and on the way back their car had broken down. They pour out of the car asking for “Amanzi” water. David tows them to try start their car - it doesn’t, he ends up towing them all the way back out the valley. Me and Gareth talk about Indonesia and throw rocks into the bushes. Throwing rocks is one of the pleasures that I indulge in when there is nothing to do.",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
