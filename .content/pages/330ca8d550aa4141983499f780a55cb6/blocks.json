    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Watching the waves from the embankment I decide it looks longboard worthy. It’s strange putting on a 5/4mm wetsuit with a hood on in the Transkei, but nobody has truly complained about being too warm - not me for sure. The rip pulling along the rocky headland gives you two choices: float at the speed of the current and have a brief chat with the people fishing on the rocks or paddle hard and watch the landscape blur past you. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Watching the waves from the embankment I decide it looks longboard worthy. It’s strange putting on a 5/4mm wetsuit with a hood on in the Transkei, but nobody has truly complained about being too warm - not me for sure. The rip pulling along the rocky headland gives you two choices: float at the speed of the current and have a brief chat with the people fishing on the rocks or paddle hard and watch the landscape blur past you. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
