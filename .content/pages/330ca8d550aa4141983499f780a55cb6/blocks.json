    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I’m out there with just Christian. It’s windy but clean and there are gentle knee high waves running down the point and the length of the sand bank. I get a few really long waves that are euphoric. Dolphins come to visit and I briefly share a wave with one of them. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
