    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "This market is reminiscent of a slightly more fancy Milnerton market in Cape Town and we trawl through the little jewellery, food, trinket and craft market. Looking for lunch we spot an Indonesian store and I am so excited to see that they have Beef Rendang. The owner of the store is surprised that I know of it and I tell her in Indonesian that I lived there for two years. There is a woman next to me in the line who laughs and tells me that she is from Java. We have a lovely chat about things and then the food arrives.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "This market is reminiscent of a slightly more fancy Milnerton market in Cape Town and we trawl through the little jewellery, food, trinket and craft market. Looking for lunch we spot an Indonesian store and I am so excited to see that they have Beef Rendang. The owner of the store is surprised that I know of it and I tell her in Indonesian that I lived there for two years. There is a woman next to me in the line who laughs and tells me that she is from Java. We have a lovely chat about things and then the food arrives.",
          "href": null
        }
      ],
      "color": "default"
