    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I have quite an emotional experience eating the Beef Rendang Nasi Champur. It’s truly authentic, probably the best Indonesian food that I’ve had outside of Indonesia. So many memories and emotions come back to me and the spice helps a tear trickle out. There is a man playing flutes and a guitar - rather badly - nearby and it kind of completes the moment. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I have quite an emotional experience eating the Beef Rendang Nasi Champur. It’s truly authentic, probably the best Indonesian food that I’ve had outside of Indonesia. So many memories and emotions come back to me and the spice helps a tear trickle out. There is a man playing flutes and a guitar - rather badly - nearby and it kind of completes the moment. ",
          "href": null
        }
      ],
      "color": "default"
