    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We take a stroll through the shops and find a massive Doc Martin stand that unfortunately is too expensive to justify Jordan buying some sandals. A man sells me a small dish that is a garlic crusher against my initial wishes - but retrospectively I’m so happy that I got it. Jordan buys me a small ring that I’ve been looking for for a while.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "We take a stroll through the shops and find a massive Doc Martin stand that unfortunately is too expensive to justify Jordan buying some sandals. A man sells me a small dish that is a garlic crusher against my initial wishes - but retrospectively I’m so happy that I got it. Jordan buys me a small ring that I’ve been looking for for a while.",
          "href": null
