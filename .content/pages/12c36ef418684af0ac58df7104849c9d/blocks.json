    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The power goes off and we head off to the Rosebank mall to get some things for Malawi. We look for a travel adapter and then pop into Pic n Pay for some dry food to bring. We manage to crush these tasks fairly quickly. We’re hungry and Jordan has the brilliant inspiration of going to the Sunday market that is the top of the parking garage. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The power goes off and we head off to the Rosebank mall to get some things for Malawi. We look for a travel adapter and then pop into Pic n Pay for some dry food to bring. We manage to crush these tasks fairly quickly. We’re hungry and Jordan has the brilliant inspiration of going to the Sunday market that is the top of the parking garage. ",
          "href": null
        }
      ],
      "color": "default"
    },
