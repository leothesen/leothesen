    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I take it easy and make some breakfast and do my goodbyes. I pop over to the ocean to see if it will entice me, but it’s stormy and quite small. I head over to Oribi gorge as per Samantha’s suggestion. ",
            "link": null
          },
