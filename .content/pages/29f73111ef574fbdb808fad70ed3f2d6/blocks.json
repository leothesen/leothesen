    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We paddled out at about 4pm, with trepidation. After watching people get minced by the rocks, broken boards and leashes and general carnage all day we were excited to see if we’d succumb to a similar fate. Yet skill (mostly luck) was on our side and we got out with dry hair. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "We paddled out at about 4pm, with trepidation. After watching people get minced by the rocks, broken boards and leashes and general carnage all day we were excited to see if we’d succumb to a similar fate. Yet skill (mostly luck) was on our side and we got out with dry hair. ",
          "href": null
        }
      ],
      "color": "default"
    },
