    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I know that Leon is silently cursing me and Nik for not being on the road already, maximizing daytime at supers - but this for me is a holiday. I’ve been there, driven to surf at 4am to ensure that I arrive there at first light. This time around it feels so easy, listen to your body and take it as it comes. ",
            "link": null
          },
          "annotations": {
