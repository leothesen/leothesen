    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "A child comes up to me, he has a constant stream of spit dripping from his mouth; his bottom lip permanently curled forwards. He doesn’t respond to my welcoming Xhosa phrases. He gestures rather randomly and makes some voices that resemble a car driving. He has warm eyes and sits down next to me. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "A child comes up to me, he has a constant stream of spit dripping from his mouth; his bottom lip permanently curled forwards. He doesn’t respond to my welcoming Xhosa phrases. He gestures rather randomly and makes some voices that resemble a car driving. He has warm eyes and sits down next to me. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
