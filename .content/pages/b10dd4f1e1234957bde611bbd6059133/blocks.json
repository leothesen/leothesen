    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The 7am yoga plan is not enough to get me out of bed this morning. I turn off all the alarms and just let the morning lie in dominate. At about 8am I find myself in the kitchen making breakfast. Jabs and his adorable son Zingi are on a similar mission. ",
            "link": null
          },
