    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I watch how his mind drifts from thought to thought and he passionately acts out intentions, without having any specific plan - so the actions quickly are abandoned. He drinks my flask dry with noises of pleasure. We hold each other’s space gently and he plays with sand contently. ",
            "link": null
          },
          "annotations": {
