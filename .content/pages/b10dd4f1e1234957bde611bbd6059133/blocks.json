    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Went to check the surf and bumped into Isipileh who had come to get his bicycle fixed again. He weaves around me on the walk to the point like an excited dog; captured by little things here and there and is not deterred by the extra distance. ",
            "link": null
          },
