    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I head for Pietermaritsberg. It’s hot and I turn on the air conditioning for the first time this road trip. The mountains loom to my left and are slowly replaced by the endless hills of KZN. I pull into an enormous shopping mall and eat an amazing curry, two rottis and four samoosas for R29 at Kara Nichas. I read the afterword of Red Dog and am once again blown away. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I head for Pietermaritsberg. It’s hot and I turn on the air conditioning for the first time this road trip. The mountains loom to my left and are slowly replaced by the endless hills of KZN. I pull into an enormous shopping mall and eat an amazing curry, two rottis and four samoosas for R29 at Kara Nichas. I read the afterword of Red Dog and am once again blown away. ",
          "href": null
