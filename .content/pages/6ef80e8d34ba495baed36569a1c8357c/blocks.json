    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I check in and then promptly leave to go for a run at the Mahai campsite which just down the road. Before I pull in I download two routes that I might be able to do. It’s a bit of a mad dash to get ready and pack my delightfully small and light running pack. I have to be out the park in just under two hours.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I check in and then promptly leave to go for a run at the Mahai campsite which just down the road. Before I pull in I download two routes that I might be able to do. It’s a bit of a mad dash to get ready and pack my delightfully small and light running pack. I have to be out the park in just under two hours.",
          "href": null
        }
      ],
      "color": "default"
