    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I run off down the path and notice that there is a whole event getting set up - there seems to be a running race tomorrow. I do a proper warm up and a bakkie stops, the guy comments on my form as I’m doing some glute exercises and I thank him with a laugh. ",
            "link": null
          },
          "annotations": {
