    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "When I come back for my burger I get stuck into a conversation with Heindrik at the bar. Born in Bloem but has lived all around the world. He has an international accent backed by Afrikaans and flavoured by Dubai. He’s living there now and I can see that his mind has been quite shaped by it. The veggie burger is incredible.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
