    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I wake up with Pebbles and give her a little cuddle. The morning starts and I’m on a slight mission to get going early. I have a nice chat with Leonard and Luke and wish them well, cash and up hit the road.",
            "link": null
