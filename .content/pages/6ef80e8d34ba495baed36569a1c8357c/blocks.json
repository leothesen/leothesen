    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I run. I run as fast as I can and then walk when I can’t run anymore. It seems to be working well for my body and I don’t feel any ITB pains. The hill is relentless and I’m not going to be able to complete the loop that I set out to do. I go find a nice high spot and sit out and look at the view for a bit and then run home. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I run. I run as fast as I can and then walk when I can’t run anymore. It seems to be working well for my body and I don’t feel any ITB pains. The hill is relentless and I’m not going to be able to complete the loop that I set out to do. I go find a nice high spot and sit out and look at the view for a bit and then run home. ",
          "href": null
