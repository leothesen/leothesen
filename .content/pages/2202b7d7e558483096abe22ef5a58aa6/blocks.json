    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "At the backpackers someone shows me and Cam their clay pottery. It’s a beautiful Grunter fish and it smells of wooden decks; varnish being used as the glaze. I tell him straight up that I’m not going to be buying anything and then proceed to really get interested in his work. He didn’t push a selling agenda but upon leaving I really hope he knew that I really enjoyed myself chatting art and fish with him. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "At the backpackers someone shows me and Cam their clay pottery. It’s a beautiful Grunter fish and it smells of wooden decks; varnish being used as the glaze. I tell him straight up that I’m not going to be buying anything and then proceed to really get interested in his work. He didn’t push a selling agenda but upon leaving I really hope he knew that I really enjoyed myself chatting art and fish with him. ",
          "href": null
        }
      ],
      "color": "default"
