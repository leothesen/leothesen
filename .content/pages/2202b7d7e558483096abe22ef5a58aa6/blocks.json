    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The waves are small and beautiful, running for 200m or so quite magically. It’s knee high and I decide to take Angelica for a christening on the Wild Coast. Wolfing down a coffee and a quarter of my overnight oats I am squeezing my legs through my wetsuit legs.",
            "link": null
          },
          "annotations": {
