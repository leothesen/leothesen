      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Walking down to the point, I see a bigger set. Placing my board on the ground I deliberate whether I should run back to get Kim. No this was just one bigger set - rather have a board for the vast majority of waves rather than just for the exceptional few. ",
            "link": null
