    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I end up having the most magical surf. It’s glorious and clean out there. Angelica is definitely the weapon of choice out there where she is able to get onto anything and glide through fast sections all the way to the beach. I have a wonderful time nose-riding out there. ",
            "link": null
          },
          "annotations": {
