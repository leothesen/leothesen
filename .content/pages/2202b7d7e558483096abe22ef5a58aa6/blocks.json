      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The 6:30am alarm feels early today. The grey clouds outside tempt me into snoozing. The alarm tries again, more insistent this time. I take a little walk down to the point under the blood red sun. ",
            "link": null
          },
          "annotations": {
