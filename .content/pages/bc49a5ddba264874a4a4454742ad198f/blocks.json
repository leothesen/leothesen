    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "In classic traveling fashion I buy a bus ticket and at that moment someone who I messaged yesterday replies and is able to sort me out with a lift to the taxi to Port St John’s. I have that wonderful drifting sensation that I knew so well from traveling around south east Asia. ",
            "link": null
          },
          "annotations": {
