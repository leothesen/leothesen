    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The bus arrives and my ticket dances around the parking lot in the wind. I manage to snatch it in time to get a seat on the front row at the top of the bus - I’ve always wanted to sit here. I watch the snaking N2 unfold as I retrace my steps back up the coast towards Port St Johns.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The bus arrives and my ticket dances around the parking lot in the wind. I manage to snatch it in time to get a seat on the front row at the top of the bus - I’ve always wanted to sit here. I watch the snaking N2 unfold as I retrace my steps back up the coast towards Port St Johns.",
          "href": null
        }
      ],
      "color": "default"
    },
