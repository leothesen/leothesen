    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Hands down my favourite wave in the Mentawais, probably on earth too. A coral reef with colours to make a rainbow blush. Surrounded by islands, the swell sneaks into the reef pass, bending around ahead of you to provide a perfectly hollow wall that grinds down the shallow, sharp spectacle under foot. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Hands down my favourite wave in the Mentawais, probably on earth too. A coral reef with colours to make a rainbow blush. Surrounded by islands, the swell sneaks into the reef pass, bending around ahead of you to provide a perfectly hollow wall that grinds down the shallow, sharp spectacle under foot. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
