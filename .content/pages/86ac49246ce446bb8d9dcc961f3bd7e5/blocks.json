    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "It takes a while to get a wave, I get one or two - but nothing to write home about. The wind turns quite soon after while the tide drops further, it quickly turns from dangerously perfect to perfectly dangerous. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "It takes a while to get a wave, I get one or two - but nothing to write home about. The wind turns quite soon after while the tide drops further, it quickly turns from dangerously perfect to perfectly dangerous. ",
          "href": null
        }
      ],
