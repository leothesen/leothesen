    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Realistically, it’s a very dangerous wave. I came away with more than a few scars to validate this point. Yet any swell with some west in it translates to a wave here that would make most people more content than they could ask for. We surfed it at waist high and fast, to head high and hollow all the way up to triple overhead where it resembled snowboarding rather than surfing. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Realistically, it’s a very dangerous wave. I came away with more than a few scars to validate this point. Yet any swell with some west in it translates to a wave here that would make most people more content than they could ask for. We surfed it at waist high and fast, to head high and hollow all the way up to triple overhead where it resembled snowboarding rather than surfing. ",
          "href": null
        }
      ],
      "color": "default"
