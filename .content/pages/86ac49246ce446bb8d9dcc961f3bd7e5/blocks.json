    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I take off on the end section and pull into one that is much wider than it is high - hands out to prove the point. With no chance of making it I surrender to the abuse that ensues. It’s a long slow paddle back from where the wave deposits you to the boats. Luckily I am collected by a small boat chartered for that very reason. Ten year old Zoe joins me - the daughter of the Kandui Villas owner - I marvel at the fact that she’s grown up surfing this wave. Ten years from now I cannot imagine how comfortable she is going to be out there. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I take off on the end section and pull into one that is much wider than it is high - hands out to prove the point. With no chance of making it I surrender to the abuse that ensues. It’s a long slow paddle back from where the wave deposits you to the boats. Luckily I am collected by a small boat chartered for that very reason. Ten year old Zoe joins me - the daughter of the Kandui Villas owner - I marvel at the fact that she’s grown up surfing this wave. Ten years from now I cannot imagine how comfortable she is going to be out there. ",
          "href": null
        }
      ],
      "color": "default"
