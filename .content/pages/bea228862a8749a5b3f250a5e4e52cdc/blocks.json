  {
    "object": "block",
    "id": "80e6095b-30ac-4db8-8c33-9b8320f844bc",
    "parent": {
      "type": "page_id",
      "page_id": "bea22886-2a87-49a5-b3f2-50a5e4e52cdc"
    },
    "created_time": "2022-07-12T06:19:00.000Z",
    "last_edited_time": "2022-07-13T09:59:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "quote",
    "quote": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Eyes \n\nYour face is home.\nI know it so well that I\nNoticed your singed\nEyelashes.\n\nYet still I can\nGet lost in your eyes.\nThe blue green bit of ocean\nYou use to see the world.\n\nMay our eyes always\nFind comfort\nIn each other.\n\n12 July 2022",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Eyes \n\nYour face is home.\nI know it so well that I\nNoticed your singed\nEyelashes.\n\nYet still I can\nGet lost in your eyes.\nThe blue green bit of ocean\nYou use to see the world.\n\nMay our eyes always\nFind comfort\nIn each other.\n\n12 July 2022",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
