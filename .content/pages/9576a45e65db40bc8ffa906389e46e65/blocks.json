    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I wake before the alarm and try find my book in the room. After failing many times I locate it under a pile of clothes. Jordan stirs and says how good she’s feeling this morning; what a relief. I leave her to sleep and go read a book.",
            "link": null
          },
