    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Dawn breaks and we don’t stir. Eventually we’re overheating in the hot room and wake up. Once again my morning routine is broken by a fake coffee (Riccoffee) but as Jordan puts it - it’s just a brown drink with caffeine, it’s not coffee. A small bowl of Futerlife and we hop in the car to head off to Delta park for a run.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Dawn breaks and we don’t stir. Eventually we’re overheating in the hot room and wake up. Once again my morning routine is broken by a fake coffee (Riccoffee) but as Jordan puts it - it’s just a brown drink with caffeine, it’s not coffee. A small bowl of Futerlife and we hop in the car to head off to Delta park for a run.",
          "href": null
        }
