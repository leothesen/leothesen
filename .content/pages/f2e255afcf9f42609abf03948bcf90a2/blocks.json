    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The morning starts slow. I’m in no rush. Oats is made correctly by measuring out a quarter cup and I’m surprised to find that it’s enough. I also determine that 25g of coffee is sufficient and extrapolate that over the length of our run next week to see how much I’m going to have to bring. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The morning starts slow. I’m in no rush. Oats is made correctly by measuring out a quarter cup and I’m surprised to find that it’s enough. I also determine that 25g of coffee is sufficient and extrapolate that over the length of our run next week to see how much I’m going to have to bring. ",
          "href": null
        }
      ],
      "color": "default"
