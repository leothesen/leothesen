    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Jordan had a beigel here last time and we take a bus and a walk to get to ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Jordan had a beigel here last time and we take a bus and a walk to get to ",
          "href": null
        },
        {
          "type": "text",
          "text": {
            "content": "Beigel Bake",
            "link": {
              "url": "https://londonist.com/london/food/things-you-probably-didn-t-know-about-beigel-bake"
            }
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Beigel Bake",
          "href": "https://londonist.com/london/food/things-you-probably-didn-t-know-about-beigel-bake"
        },
        {
          "type": "text",
          "text": {
            "content": ". We get one smoked salmon and cream cheese and another of their famous salted beef. Both are delicious but I think we both voted the smoked salmon higher. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": ". We get one smoked salmon and cream cheese and another of their famous salted beef. Both are delicious but I think we both voted the smoked salmon higher. ",
          "href": null
        }
      ],
      "color": "default"
