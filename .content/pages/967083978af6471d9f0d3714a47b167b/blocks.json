      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I go back to work tomorrow. This morning I stand on the cool London street outside Georgie and Sasha’s house and watch the beautiful morning unfold. I’m feeling ready - and quite excited - to go back to work tomorrow and begin a bit more of routine again.",
            "link": null
          },
          "annotations": {
