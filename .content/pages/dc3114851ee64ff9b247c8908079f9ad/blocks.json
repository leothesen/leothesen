    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The cheese shop is authentic and run by truly passionate and fun people. We order the one sandwich on their menu and then begin to look around. One of the staff gives us a little bit of everything to try, accompanied by truffle honey and chilli jams that is truly a highlight. The sandwich arrives - two massive slices of bread with many different kinds of melted cheese inside with sprinklings of mustard and chopped vegetables. Truly delicious. Actually I’m going to say the best toasted cheese I’ve ever had.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "The cheese shop is authentic and run by truly passionate and fun people. We order the one sandwich on their menu and then begin to look around. One of the staff gives us a little bit of everything to try, accompanied by truffle honey and chilli jams that is truly a highlight. The sandwich arrives - two massive slices of bread with many different kinds of melted cheese inside with sprinklings of mustard and chopped vegetables. Truly delicious. Actually I’m going to say the best toasted cheese I’ve ever had.",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
