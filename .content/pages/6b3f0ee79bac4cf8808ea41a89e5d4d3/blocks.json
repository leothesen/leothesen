    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "It’s hard to wake up this morning. I slowly get out of bed and find that the power is off. After a bowl of oats - which again I make too much of - me and Jordan head over to her favourite ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "It’s hard to wake up this morning. I slowly get out of bed and find that the power is off. After a bowl of oats - which again I make too much of - me and Jordan head over to her favourite ",
          "href": null
        },
        {
          "type": "text",
          "text": {
            "content": "coffee shop",
            "link": {
              "url": "https://niceon4th.co.za/"
            }
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "coffee shop",
          "href": "https://niceon4th.co.za/"
        },
        {
          "type": "text",
          "text": {
            "content": " called Nice to do some work. It’s nice.",
