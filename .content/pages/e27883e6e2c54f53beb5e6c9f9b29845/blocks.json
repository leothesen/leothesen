      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Today is the 11th - which marks a “monthiversary” for Leo and Jordan. We slowly wake up in a sunny room wrapped in a single bed. I had thought that we were also using a single duvet, but it turns out that Jordan had been reeling it in all night haha. ",
            "link": null
