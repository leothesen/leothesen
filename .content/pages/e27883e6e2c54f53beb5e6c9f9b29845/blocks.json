      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "My bank card has finally arrived today after it being allegedly promised since Monday. This was potentially a piece of admin that could have caused some unneeded running around next week. Jordan has a conference later and I have a long overdue date with the Drifters store here that looks much bigger and better than the Cape Town branch. ",
            "link": null
          },
