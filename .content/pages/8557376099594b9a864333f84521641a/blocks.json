    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "After the call Jordan has energy and suggests we rent a kayak and explore the small islands just off the coast. We hop in and glide out through the impossibly soft, still and quiet lake. The horizon is almost unrecognisable as the colour of the water fades into that of the sky. Fish Eagles cry out from their roosts and tropical fish swim in abundance just below the surface.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "After the call Jordan has energy and suggests we rent a kayak and explore the small islands just off the coast. We hop in and glide out through the impossibly soft, still and quiet lake. The horizon is almost unrecognisable as the colour of the water fades into that of the sky. Fish Eagles cry out from their roosts and tropical fish swim in abundance just below the surface.",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
