    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "We take a very slow morning. Have a swim and enjoy some eggs on toast on a picnic table with our feet in sand. A lovely man named Austin accompanies us into town and we pop into a few shops for some supplies. We take Metta to a mechanic to repair her broken headlight casing and refusal to start first time in the morning.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "We take a very slow morning. Have a swim and enjoy some eggs on toast on a picnic table with our feet in sand. A lovely man named Austin accompanies us into town and we pop into a few shops for some supplies. We take Metta to a mechanic to repair her broken headlight casing and refusal to start first time in the morning.",
          "href": null
        }
      ],
      "color": "default"
