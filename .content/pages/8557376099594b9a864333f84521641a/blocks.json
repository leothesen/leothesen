    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The enormous, smooth granite rocks protrude from the water to form islands and we marvel at this isolated pieces of thriving vegetation and life. We traverse the island to the right in a clockwise direction spot another lodge on a small beach not too far away. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
