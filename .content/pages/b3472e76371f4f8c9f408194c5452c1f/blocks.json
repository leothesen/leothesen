    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I’ve been looking for those black and white stripy leashes but cannot find them anywhere. I see the first person with shark repellant band on. I head off to “The Kitchen Table” on my friend Jess’ recommendation. I brave ordering a Cortado in the Eastern Cape - the risk pays off. If I feel energised after lunch I’m going to give Nahoon a paddle. I’m going to drive back to Nahoon and see how it’s looking.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I’ve been looking for those black and white stripy leashes but cannot find them anywhere. I see the first person with shark repellant band on. I head off to “The Kitchen Table” on my friend Jess’ recommendation. I brave ordering a Cortado in the Eastern Cape - the risk pays off. If I feel energised after lunch I’m going to give Nahoon a paddle. I’m going to drive back to Nahoon and see how it’s looking.",
          "href": null
        }
      ],
      "color": "default"
