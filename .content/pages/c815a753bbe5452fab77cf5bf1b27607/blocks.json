      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Safe slow driving. The lack of a rush is palpable. I rarely hit 40km/h, am shifting down to first fairly often and the last 20 kilometres of dirt take me almost as long as the tar section. But I love it, it’s what I’m here for. The kids are yelling sweets as always, life bustles. ",
            "link": null
          },
