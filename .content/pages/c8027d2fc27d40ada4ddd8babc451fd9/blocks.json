    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "The airplane dips threateningly close to the impenetrable cloud bank below us. We toy with it for a while before taking the plunge. Turbulence and iridescent white sparkles takes over the plane until we break out the bottom and are presented with a magnificent delta, mangroves and the turquoise ocean expanding forever below us. The black sails of the dhows providing some contrast. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
