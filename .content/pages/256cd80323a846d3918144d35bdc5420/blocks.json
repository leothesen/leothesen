  {
    "object": "block",
    "id": "b288c888-12bb-4853-b812-e45debfdfd55",
    "parent": {
      "type": "page_id",
      "page_id": "256cd803-23a8-46d3-9181-44d35bdc5420"
    },
    "created_time": "2022-09-06T09:38:00.000Z",
    "last_edited_time": "2022-09-06T09:40:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I really want to catch a wave with the dolphins but no opportunity presents itself. I get a smaller one and it’s a nice big drop but not much more. I’ve decided to try kick out early on waves to give my arms a bit of a rest, as I don’t think I can do another walk around and big paddle out. A set appears and it’s full of dolphins. I take off in the lip and somehow manage to set the rail and shoot out down the wall. I can see their forms as they glide just under the surface. Their dorsal fins almost the mirror of my surfboard fin. ",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I really want to catch a wave with the dolphins but no opportunity presents itself. I get a smaller one and it’s a nice big drop but not much more. I’ve decided to try kick out early on waves to give my arms a bit of a rest, as I don’t think I can do another walk around and big paddle out. A set appears and it’s full of dolphins. I take off in the lip and somehow manage to set the rail and shoot out down the wall. I can see their forms as they glide just under the surface. Their dorsal fins almost the mirror of my surfboard fin. ",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
