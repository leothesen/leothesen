    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Chilling in the sun room and putting the movie together from the run. The lifeguard named Olwetu arrives and tells me about living here. We put the rules in “rural” - no police here but there is no crime.",
            "link": null
          },
