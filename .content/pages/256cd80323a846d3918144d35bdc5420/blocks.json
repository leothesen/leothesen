    "created_time": "2022-09-06T09:30:00.000Z",
    "last_edited_time": "2022-09-06T09:31:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I run back and quickly eat some boiled eggs on Provitas. Wetsuit, suncream and The Custard Queen. It has to be a rock jump today. I wait on the edge of the ocean and watch. But it seems that right now is actually the time to paddle so I trust my gut and paddle hard. Only one or two waves require a duck dive and I make it out to the back with ease.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I run back and quickly eat some boiled eggs on Provitas. Wetsuit, suncream and The Custard Queen. It has to be a rock jump today. I wait on the edge of the ocean and watch. But it seems that right now is actually the time to paddle so I trust my gut and paddle hard. Only one or two waves require a duck dive and I make it out to the back with ease.",
          "href": null
        }
      ],
      "color": "default"
    },
