  {
    "object": "block",
    "id": "00b28dd1-5b4a-4d91-9598-e07954b92151",
    "parent": {
      "type": "page_id",
      "page_id": "256cd803-23a8-46d3-9181-44d35bdc5420"
    },
    "created_time": "2022-09-06T09:31:00.000Z",
    "last_edited_time": "2022-09-06T09:36:00.000Z",
    "created_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "last_edited_by": {
      "object": "user",
      "id": "a89840a5-a507-41f8-ad65-4d62341efbc9"
    },
    "has_children": false,
    "in_trash": false,
    "type": "paragraph",
    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I’m tempted by a few smaller waves that come through. Sometimes it’s nice to just get one wave on a big day to bring you into the surf. I set comes through and I’m in the spot. It’s a big drop and I have to squint through the wind as I speed up. It was a silly wave to go for and a big section forces me to jump off and I get tumbled about for a while. I’m definitely feeling in it now. A few big sets catch me off guard and I do some time underwater. Luckily the rip isn’t bad today so gaining ground up the point is quite easy.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "I’m tempted by a few smaller waves that come through. Sometimes it’s nice to just get one wave on a big day to bring you into the surf. I set comes through and I’m in the spot. It’s a big drop and I have to squint through the wind as I speed up. It was a silly wave to go for and a big section forces me to jump off and I get tumbled about for a while. I’m definitely feeling in it now. A few big sets catch me off guard and I do some time underwater. Luckily the rip isn’t bad today so gaining ground up the point is quite easy.",
          "href": null
        }
      ],
      "color": "default"
    },
    "archived": false
  },
