    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "I get two more waves and on my last one I decide that it would be an appropriate time to call it for the session. I bodysurf in and see that Marcus from yesterday evening is watching and head up for a chat. We decide that it might have calmed down a bit by this evening so will try and link up then. ",
            "link": null
          },
