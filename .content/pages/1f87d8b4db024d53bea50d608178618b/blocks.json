    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Filen tells me about how he’s on a mission to unite Ayurvedic methods with Xhosa healing. It’s fascinating and I think that his approach to it is sound. He’s going to be moving to a plot of land just up from the backpackers to live for a while.",
            "link": null
          },
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
            "color": "default"
          },
          "plain_text": "Filen tells me about how he’s on a mission to unite Ayurvedic methods with Xhosa healing. It’s fascinating and I think that his approach to it is sound. He’s going to be moving to a plot of land just up from the backpackers to live for a while.",
          "href": null
        }
      ],
      "color": "default"
