    "paragraph": {
      "rich_text": [
        {
          "type": "text",
          "text": {
            "content": "Today’s plan is to just relax and do some writing. I manage to catch up on yesterday’s travel journal - one that I was physically too exhausted to even attempt. Fabio, Andrea and their friend pull into the backpackers for breakfast and we reconcile our overlapping circles and remember that parties that we’ve met. ",
            "link": null
          },
          "annotations": {
